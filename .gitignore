# Ignore all dotfiles
.*

*.llm_update
*.log
*.bak
__pycache__

query_result*

# But don't ignore .gitignore
!.gitignore

# Virtual environments (at any level in the repo)
venv/
.venv/

# Node modules (at any level in the repo)
node_modules/

# Scratch/temporary work directory
scratch/

# Build artifacts
shared_quickscribe_py/build/
shared_quickscribe_py/dist/

# Generated reports
scripts/consistency_report.json

# Production secrets - NEVER commit
backend/production_settings.json

# Plaud sync deploy packages
plaud_sync_service/plaud_deploy_*/
