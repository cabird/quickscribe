{
  "name": "quickscribe-v3-frontend",
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/sync-models.js && vite",
    "build": "node scripts/sync-models.js && tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'",
    "sync-models": "node scripts/sync-models.js",
    "deploy:copy": "rm -rf ../backend/src/frontend-dist/* && cp -r dist/* ../backend/src/frontend-dist/",
    "deploy:build-and-copy": "npm run build && npm run deploy:copy"
  },
  "dependencies": {
    "@azure/msal-browser": "^4.26.1",
    "@azure/msal-react": "^3.0.21",
    "@fluentui/react-components": "^9.72.7",
    "@fluentui/react-icons": "^2.0.314",
    "@vitejs/plugin-react": "^5.1.1",
    "axios": "^1.13.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.6",
    "react-toastify": "^11.0.5",
    "vite": "^7.2.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
