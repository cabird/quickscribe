# .env.local.template
# Copy this file to .env.local and fill in your values

# Azure Storage Connection String
# Get this from your Azure Storage Account > Access keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net

# Queue Name for transcoding jobs
TRANSCODING_QUEUE_NAME=transcoding-queue

# Optional: Container Version (defaults to value in Dockerfile)
# CONTAINER_VERSION=1.0.0-local

# Optional: Log Level
# LOG_LEVEL=INFO

# Optional: Processing timeout in seconds
# PROCESSING_TIMEOUT=1800
